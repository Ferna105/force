# Copiá este archivo a .env  (cp .env.example .env) antes de "docker compose up".
# Estos valores son SOLO para desarrollo local. Generá secretos nuevos para producción
# (p. ej.:  node -e "console.log(require('crypto').randomBytes(16).toString('base64'))").

# --- Base de datos (Postgres) ---
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi

# --- Secretos de Strapi (dev) ---
APP_KEYS=devKeyOne==,devKeyTwo==
API_TOKEN_SALT=devApiTokenSalt==
ADMIN_JWT_SECRET=devAdminJwtSecret==
TRANSFER_TOKEN_SALT=devTransferTokenSalt==
JWT_SECRET=devJwtSecret==

# --- Frontend ---
# URL del backend tal como la ve el navegador (puerto publicado en el host).
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337
