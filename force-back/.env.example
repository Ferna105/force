HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# Tareas programadas (cron). El cron de reabastecimiento de tiendas
# (config/cron-tasks.js) corre cada minuto. Default: true (activado).
# Poner en false para desactivarlo (p. ej. en entornos de desarrollo/prod
# donde no se quiere consumir recursos). El seed sigue generando el stock
# inicial en cada deploy aunque el cron esté apagado.
CRON_ENABLED=true
