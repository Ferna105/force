{
  "kind": "collectionType",
  "collectionName": "up_users",
  "info": {
    "name": "user",
    "description": "",
    "singularName": "user",
    "pluralName": "users",
    "displayName": "User"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "username": {
      "type": "string",
      "minLength": 3,
      "unique": true,
      "configurable": false,
      "required": true
    },
    "email": {
      "type": "email",
      "minLength": 6,
      "configurable": false,
      "required": true
    },
    "provider": {
      "type": "string",
      "configurable": false
    },
    "password": {
      "type": "password",
      "minLength": 6,
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "resetPasswordToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmationToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmed": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "blocked": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "role": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.role",
      "inversedBy": "users",
      "configurable": false
    },
    "items": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::item.item",
      "inversedBy": "users"
    },
    "balance": {
      "type": "integer",
      "default": 500,
      "min": 0
    },
    "gameCooldowns": {
      "type": "json",
      "private": true
    },
    "gameBestScores": {
      "type": "json",
      "private": true
    },
    "discoveredMonsters": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::monster.monster"
    },
    "inventoryEntries": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::inventory-entry.inventory-entry",
      "mappedBy": "user"
    },
    "companions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::companion.companion",
      "mappedBy": "user"
    }
  }
}
